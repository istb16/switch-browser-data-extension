{
  "manifest_version": 3,
  "name": "__MSG_name__",
  "version": "1.0.1",
  "default_locale": "ja",
  "description": "__MSG_description__",
  "permissions": ["cookies", "storage", "scripting", "activeTab", "tabs"],
  "optional_host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options/options.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "lib/web-storage-handlers.js",
        "lib/indexeddb-handler.js",
        "content/content-script.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
